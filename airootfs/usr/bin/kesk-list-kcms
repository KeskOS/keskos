#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/../lib/kesk/lib/kcm_cleanup_common.sh"

print_ids() {
  local title="$1"
  shift
  local id=""

  printf '%s\n' "${title}"
  if [[ $# -eq 0 ]]; then
    printf '  (none)\n'
    return 0
  fi
  for id in "$@"; do
    printf '  %s\n' "${id}"
  done
}

usage() {
  cat <<'EOF'
Usage: kesk-list-kcms [--system|--user] [--root PATH] [--home PATH]
EOF
}

main() {
  local arg=""
  local list_bin=""
  local temp_output=""

  KESK_KCM_MODE=""
  KESK_KCM_ROOT=""
  KESK_KCM_HOME="${HOME}"

  while [[ $# -gt 0 ]]; do
    arg="$1"
    case "${arg}" in
      --system)
        KESK_KCM_MODE="system"
        shift
        ;;
      --user)
        KESK_KCM_MODE="user"
        shift
        ;;
      --root)
        KESK_KCM_ROOT="${2:-}"
        shift 2
        ;;
      --home)
        KESK_KCM_HOME="${2:-}"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        printf 'kesk-list-kcms: unknown option: %s\n' "${arg}" >&2
        usage >&2
        return 1
        ;;
    esac
  done

  if [[ -z "${KESK_KCM_MODE}" ]]; then
    if [[ ${EUID} -eq 0 ]]; then
      KESK_KCM_MODE="system"
    else
      KESK_KCM_MODE="user"
    fi
  fi

  kesk_kcm_resolve_paths
  kesk_kcm_ensure_dirs

  list_bin="$(kesk_kcm_available_list_bin || true)"
  if [[ -z "${list_bin}" ]]; then
    printf 'kesk-list-kcms: kcmshell6/5 was not found\n' >&2
    return 1
  fi

  temp_output="$(mktemp)"
  "${list_bin}" --list | tee "${temp_output}" "${KESK_KCM_USER_LIST_OUTPUT}"
  printf '\nSaved module list to %s\n\n' "${KESK_KCM_USER_LIST_OUTPUT}"

  kesk_kcm_parse_ids 0
  print_ids "Default hidden KCMs (${KESK_KCM_PRIMARY_CONF}):" "${KESK_KCM_IDS[@]}"
  printf '\n'

  kesk_kcm_parse_ids 1
  print_ids "Default + optional hidden KCMs (${KESK_KCM_PRIMARY_CONF} + ${KESK_KCM_EXTRA_CONF}):" "${KESK_KCM_IDS[@]}"
  printf '\n'

  kesk_kcm_read_managed_ids "${KESK_KCM_KDEGLOBALS}"
  print_ids "Currently managed restrictions in ${KESK_KCM_KDEGLOBALS}:" "${KESK_KCM_MANAGED_IDS[@]}"

  if [[ -f "${KESK_KCM_DEFAULT_LIST}" ]]; then
    printf '\nSystem reference list: %s\n' "${KESK_KCM_DEFAULT_LIST}"
  fi

  rm -f "${temp_output}"
}

main "$@"
