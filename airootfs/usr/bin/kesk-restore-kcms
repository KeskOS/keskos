#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/../lib/kesk/lib/kcm_cleanup_common.sh"

usage() {
  cat <<'EOF'
Usage: kesk-restore-kcms [--system|--user] [--root PATH] [--home PATH] [--quiet]
EOF
}

main() {
  local arg=""

  KESK_KCM_MODE=""
  KESK_KCM_ROOT=""
  KESK_KCM_HOME="${HOME}"
  KESK_KCM_QUIET=0

  while [[ $# -gt 0 ]]; do
    arg="$1"
    case "${arg}" in
      --system)
        KESK_KCM_MODE="system"
        shift
        ;;
      --user)
        KESK_KCM_MODE="user"
        shift
        ;;
      --root)
        KESK_KCM_ROOT="${2:-}"
        shift 2
        ;;
      --home)
        KESK_KCM_HOME="${2:-}"
        shift 2
        ;;
      --quiet)
        KESK_KCM_QUIET=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        printf 'kesk-restore-kcms: unknown option: %s\n' "${arg}" >&2
        usage >&2
        return 1
        ;;
    esac
  done

  if [[ -z "${KESK_KCM_MODE}" ]]; then
    if [[ ${EUID} -eq 0 ]]; then
      KESK_KCM_MODE="system"
    else
      KESK_KCM_MODE="user"
    fi
  fi

  if [[ "${KESK_KCM_MODE}" == "system" && ${EUID} -ne 0 && -z "${KESK_KCM_ROOT}" ]]; then
    printf 'kesk-restore-kcms: system mode requires root unless --root is used for staging/testing\n' >&2
    return 1
  fi

  kesk_kcm_resolve_paths
  kesk_kcm_restore_block
}

main "$@"
