#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys


def main() -> int:
    command = ["kesk-welcome", *sys.argv[1:]]
    if os.name == "nt":
        return subprocess.call(command)
    os.execvp(command[0], command)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
