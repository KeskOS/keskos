#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[keskos-postinstall] %s\n' "$1"
}

apply_install_choices() {
  local target_user="$1"
  local helper="/usr/lib/keskos-installer/apply-install-choices.sh"

  [[ -x "$helper" ]] || return 0

  if [[ -n "$target_user" ]]; then
    TARGET_USER="$target_user" "$helper" || true
  else
    "$helper" || true
  fi
}

write_sddm_login_defaults() {
  local target_user="$1"
  [[ -n "$target_user" ]] || return 0

  mkdir -p /etc/sddm.conf.d /var/lib/sddm
  cat >/etc/sddm.conf.d/keskos-login.conf <<'EOF'
[Users]
RememberLastUser=true
RememberLastSession=true
EOF

  cat >/var/lib/sddm/state.conf <<EOF
[Last]
User=${target_user}
Session=plasma.desktop
EOF

}

detect_target_user() {
  awk -F: '
    $1 != "liveuser" &&
    $1 != "nobody" &&
    $3 >= 1000 &&
    $7 !~ /(nologin|false)$/ {
      print $1
      exit
    }
  ' /etc/passwd
}

write_installed_os_release() {
  cat >/etc/os-release <<'EOF'
NAME="KeskOS"
PRETTY_NAME="KeskOS"
ID=arch
ID_LIKE=arch
BUILD_ID=rolling
ANSI_COLOR="38;2;206;106;53"
HOME_URL="https://github.com/memegeko/keskos"
DOCUMENTATION_URL="https://github.com/memegeko/keskos"
SUPPORT_URL="https://github.com/memegeko/keskos/issues"
BUG_REPORT_URL="https://github.com/memegeko/keskos/issues"
PRIVACY_POLICY_URL="https://github.com/memegeko/keskos"
LOGO=archlinux-logo
EOF
}

initialize_installed_pacman_keyring() {
  if ! command -v pacman-key >/dev/null 2>&1; then
    log "pacman-key is unavailable; skipping installed keyring refresh."
    return 0
  fi

  log "Refreshing installed pacman keyring trust database."
  pacman-key --init >/dev/null 2>&1 || true
  pacman-key --populate archlinux >/dev/null 2>&1 || true
}

enable_bluetooth_service_on_installed_system() {
  if command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files bluetooth.service >/dev/null 2>&1; then
    systemctl enable bluetooth.service >/dev/null 2>&1 || true
  fi
}

disable_networkd_on_installed_system() {
  if command -v systemctl >/dev/null 2>&1; then
    systemctl disable systemd-networkd.service systemd-networkd.socket systemd-networkd-wait-online.service >/dev/null 2>&1 || true
  fi

  rm -f /etc/systemd/network/20-ethernet.network
  rm -f /etc/systemd/network/20-wlan.network
  rm -rf /etc/systemd/system/systemd-networkd-wait-online.service.d
}

hide_launcher_entry() {
  local desktop_id="$1"
  local name="$2"
  local target_path="/usr/local/share/applications/${desktop_id}"

  mkdir -p /usr/local/share/applications
  if [[ -f "$target_path" ]] && grep -qxF 'Hidden=true' "$target_path" && grep -qxF 'NoDisplay=true' "$target_path"; then
    return 0
  fi

  cat >"$target_path" <<EOF
[Desktop Entry]
Type=Application
Hidden=true
NoDisplay=true
Name=${name}
EOF
}

hide_unwanted_launcher_entries() {
  hide_launcher_entry calamares.desktop Calamares
  hide_launcher_entry install-keskos-debug.desktop "KeskOS Installer Debug Log"
  hide_launcher_entry assistant.desktop "Qt Assistant"
  hide_launcher_entry designer.desktop "Qt Designer"
  hide_launcher_entry linguist.desktop "Qt Linguist"
  hide_launcher_entry qdbusviewer.desktop "QDBusViewer"
  hide_launcher_entry bssh.desktop "Avahi SSH Server Browser"
  hide_launcher_entry bvnc.desktop "Avahi VNC Server Browser"
  hide_launcher_entry ktelnetservice6.desktop "KTelnetService"
  hide_launcher_entry avahi-discover.desktop "Avahi Zeroconf Browser"
  hide_launcher_entry org.kde.plasma.emojier.desktop "Emoji Selector"
}

remove_live_only_packages() {
  local package=""
  local packages=(
    arch-install-scripts
    archiso
    calamares
    keskos-calamares-branding
    keskos-installer-debug-log
    mkinitcpio-archiso
  )

  command -v pacman >/dev/null 2>&1 || return 0

  for package in "${packages[@]}"; do
    if pacman -Qq "$package" >/dev/null 2>&1; then
      pacman -Rdd --noconfirm "$package" >/dev/null 2>&1 || log "Could not remove live-only package ${package}; continuing."
    fi
  done
}

cleanup_live_bits() {
  rm -f /etc/sudoers.d/10-liveuser
  rm -f /etc/sddm.conf.d/keskos-live.conf
  rm -f /etc/mkinitcpio.conf.d/archiso.conf
  disable_networkd_on_installed_system
  enable_bluetooth_service_on_installed_system
  rm -f /usr/share/applications/install-keskos.desktop
  rm -f /etc/skel/Desktop/Install\ KeskOS.desktop
  mkdir -p /usr/local/share/applications
  hide_unwanted_launcher_entries

  if id -u liveuser >/dev/null 2>&1; then
    userdel -r liveuser >/dev/null 2>&1 || true
  else
    rm -rf /home/liveuser
  fi

}

configure_target_user() {
  local target_user="$1"
  local target_home=""

  target_home="$(getent passwd "$target_user" | cut -d: -f6)"
  [[ -n "$target_home" ]] || return 0

  rm -f "$target_home/Desktop/Install KeskOS.desktop"
  TARGET_USER="$target_user" /usr/local/bin/keskos-configure-user --offline --force || true
  chown -R "$target_user:$target_user" "$target_home" >/dev/null 2>&1 || true
}

main() {
  local target_user=""

  write_installed_os_release
  initialize_installed_pacman_keyring
  cleanup_live_bits
  target_user="$(detect_target_user || true)"
  log "Applying Calamares software loadout choices."
  apply_install_choices "$target_user"
  if [[ -n "$target_user" ]]; then
    write_sddm_login_defaults "$target_user"
    log "Configuring installed user defaults for ${target_user}"
    configure_target_user "$target_user"
  else
    log "No target desktop user was detected during post-install."
  fi
  remove_live_only_packages
  log "KeskOS post-install tasks complete."
}

main "$@"
