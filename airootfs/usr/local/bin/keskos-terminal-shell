#!/usr/bin/env bash
set -euo pipefail

shell_bin="${SHELL:-/bin/bash}"
user_fastfetch_config="${HOME}/.config/fastfetch/config.jsonc"
bash_rc_override="${HOME}/.config/keskos/bashrc"
branding_helper="/usr/lib/keskos/branding.sh"

find_system_fastfetch_config() {
  local candidate=""

  for candidate in \
    "${KESKOS_SOURCE_ROOT:-}/configs/fastfetch/config.jsonc" \
    "/usr/local/share/keskos/source/configs/fastfetch/config.jsonc" \
    "/usr/share/keskos/source/configs/fastfetch/config.jsonc" \
    "/usr/share/keskos/defaults/fastfetch/config.jsonc"
  do
    [[ -n "$candidate" ]] || continue
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

system_fastfetch_config="$(find_system_fastfetch_config || true)"

if [[ ! -x "$shell_bin" ]]; then
  shell_bin="/bin/bash"
fi

if [[ -r "$branding_helper" ]]; then
  # shellcheck disable=SC1090
  . "$branding_helper"
fi

if [[ -t 1 && -z "${KESKOS_FASTFETCH_SHOWN:-}" ]]; then
  export KESKOS_FASTFETCH_SHOWN=1
  printf '\033]0;%s\007' "${OS_BRAND_LINE:-KeskOS} Terminal"
  if command -v fastfetch >/dev/null 2>&1; then
    if [[ -f "$user_fastfetch_config" ]]; then
      fastfetch --config "$user_fastfetch_config" || true
    elif [[ -f "$system_fastfetch_config" ]]; then
      fastfetch --config "$system_fastfetch_config" || true
    else
      fastfetch || true
    fi
    printf '\n'
  fi
fi

case "$(basename "$shell_bin")" in
  bash)
    if [[ -f "$bash_rc_override" ]]; then
      exec "$shell_bin" --rcfile "$bash_rc_override" -i
    fi
    exec "$shell_bin" -l
    ;;
  nu|nushell)
    exec "$shell_bin" --login
    ;;
  sh|dash|zsh|fish|ksh|mksh)
    exec "$shell_bin" -l
    ;;
  *)
    exec "$shell_bin"
    ;;
esac
